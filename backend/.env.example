# Stadium Command Center — Backend Environment Variables

# Server
NODE_ENV=development
PORT=4000

# Google Gemini (optional — falls back to deterministic mode when absent)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database (optional in development — knowledge retrieval degrades gracefully)
# DATABASE_URL=postgresql://user:password@localhost:5432/stadium

# Redis (optional — caching degrades gracefully)
# REDIS_URL=redis://localhost:6379

# JWT (optional in development)
# JWT_SECRET=your-32-char-minimum-secret-key-here!!
# JWT_REFRESH_SECRET=your-32-char-minimum-refresh-key-here!!
